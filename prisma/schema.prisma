generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                                  String               @id @default(uuid())
  phone                               String?              @unique
  email                               String?              @unique
  photoUrl                            String?
  address                             String?
  pincode                             String?
  designation                         String?
  dateOfBirth                         DateTime?
  createdAt                           DateTime             @default(now())
  updatedAt                           DateTime             @updatedAt
  gender                              Gender?
  area                                String?
  bloodGroup                          String?
  community                           String?
  education                           String?
  firstName                           String?
  lastName                            String?
  maritalStatus                       String?
  matrimonialStatus                   String?
  middleName                          String?
  occupation                          String?
  occupationDetails                   String?
  religion                            String?
  whatsapp                            String?
  profileCompleted                    Boolean              @default(false)
  isRegistered                        Boolean              @default(false)
  bio                                 String?
  deletedAt                           DateTime?
  isAlive                             Boolean              @default(true)
  isPrivate                           Boolean              @default(false)
  conversationMembers                 ConversationMember[]
  following                           Follow[]             @relation("Follower")
  followers                           Follow[]             @relation("Following")
  sentMessages                        Message[]            @relation("MessageSender")
  messageReads                        MessageRead[]
  notifications                       Notification[]
  posts                               Post[]
  postComments                        PostComment[]
  postLikes                           PostLike[]
  postShares                          PostShare[]
  Relation_Relation_createdByIdToUser Relation[]           @relation("Relation_createdByIdToUser")
  relationsFrom                       Relation[]           @relation("UserRelationsFrom")
  relationsTo                         Relation[]           @relation("UserRelationsTo")
  stories                             Story[]
  storyViews                          StoryView[]
  blockedByUsers                      UserBlock[]          @relation("Blocked")
  blockedUsers                        UserBlock[]          @relation("BlockedBy")
}

model RelationType {
  code           String                @id
  category       RelationCategory
  targetGender   Gender?
  treeLevel      Int?          // Canonical generation level (0=root, 2=parents, -1=children, etc.)
  treeSide       String?       // 'ROOT' | 'SPOUSE' — which side of the tree this relation belongs to
  reciprocalCode String?
  relations      Relation[]
  translations   RelationTranslation[]

  @@index([category])
}

model RelationTranslation {
  id               String       @id @default(uuid())
  relationTypeCode String
  languageCode     String
  community        String?
  label            String
  createdAt        DateTime     @default(now())
  relationType     RelationType @relation(fields: [relationTypeCode], references: [code])

  @@unique([relationTypeCode, languageCode, community])
  @@index([languageCode])
}

model Relation {
  id                              String           @id @default(uuid())
  fromUserId                      String
  toUserId                        String
  status                          RelationStatus   @default(PENDING)
  createdAt                       DateTime         @default(now())
  updatedAt                       DateTime         @updatedAt
  relationTypeCode                String
  customName                      String?
  customPhotoUrl                  String?
  category                        RelationCategory
  createdById                     String?
  deletedAt                       DateTime?
  notifications                   Notification[]
  User_Relation_createdByIdToUser User?            @relation("Relation_createdByIdToUser", fields: [createdById], references: [id])
  fromUser                        User             @relation("UserRelationsFrom", fields: [fromUserId], references: [id])
  relationType                    RelationType     @relation(fields: [relationTypeCode], references: [code])
  toUser                          User             @relation("UserRelationsTo", fields: [toUserId], references: [id])

  @@unique([fromUserId, toUserId, relationTypeCode])
  @@index([fromUserId])
  @@index([toUserId])
  @@index([relationTypeCode])
  @@index([category])
  @@index([status])
}

model Notification {
  id         String            @id @default(uuid())
  userId     String
  type       NotificationType
  title      String
  message    String
  relationId String?
  state      NotificationState @default(UNREAD)
  createdAt  DateTime          @default(now())
  readAt     DateTime?
  postId     String?
  post       Post?             @relation(fields: [postId], references: [id])
  relation   Relation?         @relation(fields: [relationId], references: [id])
  user       User              @relation(fields: [userId], references: [id])

  @@index([userId, state, createdAt])
  @@index([relationId])
  @@index([postId])
}

model Post {
  id            String         @id @default(uuid())
  userId        String
  caption       String?
  location      String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  deletedAt     DateTime?
  notifications Notification[]
  user          User           @relation(fields: [userId], references: [id])
  comments      PostComment[]
  likes         PostLike[]
  media         PostMedia[]
  shares        PostShare[]

  @@index([userId, createdAt])
  @@index([createdAt])
}

model PostMedia {
  id     String    @id @default(uuid())
  postId String
  url    String
  type   MediaType
  order  Int       @default(0)
  post   Post      @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@index([postId])
}

model PostLike {
  id        String   @id @default(uuid())
  postId    String
  userId    String
  createdAt DateTime @default(now())
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id])

  @@unique([postId, userId])
  @@index([postId])
}

model PostComment {
  id        String        @id @default(uuid())
  postId    String
  userId    String
  content   String
  parentId  String?
  createdAt DateTime      @default(now())
  deletedAt DateTime?
  parent    PostComment?  @relation("CommentReplies", fields: [parentId], references: [id])
  replies   PostComment[] @relation("CommentReplies")
  post      Post          @relation(fields: [postId], references: [id], onDelete: Cascade)
  user      User          @relation(fields: [userId], references: [id])

  @@index([postId, createdAt])
  @@index([parentId])
}

model PostShare {
  id        String   @id @default(uuid())
  postId    String
  userId    String
  sharedTo  String?
  createdAt DateTime @default(now())
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id])

  @@index([postId])
}

model Story {
  id        String      @id @default(uuid())
  userId    String
  mediaUrl  String
  mediaType MediaType
  caption   String?
  expiresAt DateTime
  createdAt DateTime    @default(now())
  deletedAt DateTime?
  user      User        @relation(fields: [userId], references: [id])
  views     StoryView[]

  @@index([userId, expiresAt])
  @@index([expiresAt])
}

model StoryView {
  id       String   @id @default(uuid())
  storyId  String
  userId   String
  viewedAt DateTime @default(now())
  story    Story    @relation(fields: [storyId], references: [id], onDelete: Cascade)
  viewer   User     @relation(fields: [userId], references: [id])

  @@unique([storyId, userId])
  @@index([storyId])
}

model Follow {
  id          String       @id @default(uuid())
  followerId  String
  followingId String
  status      FollowStatus @default(PENDING)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  follower    User         @relation("Follower", fields: [followerId], references: [id])
  following   User         @relation("Following", fields: [followingId], references: [id])

  @@unique([followerId, followingId])
  @@index([followerId])
  @@index([followingId])
  @@index([status])
}

model Conversation {
  id          String               @id @default(uuid())
  name        String?
  photoUrl    String?
  isGroup     Boolean              @default(false)
  category    RelationCategory
  createdById String
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt
  members     ConversationMember[]
  messages    Message[]

  @@index([createdById])
  @@index([category])
}

model ConversationMember {
  id             String       @id @default(uuid())
  conversationId String
  userId         String
  role           MemberRole   @default(MEMBER)
  joinedAt       DateTime     @default(now())
  lastReadAt     DateTime?
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id])

  @@unique([conversationId, userId])
  @@index([userId])
}

model Message {
  id             String        @id @default(uuid())
  conversationId String
  senderId       String
  content        String?
  mediaUrl       String?
  mediaType      MediaType?
  type           MessageType   @default(TEXT)
  deletedAt      DateTime?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  conversation   Conversation  @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender         User          @relation("MessageSender", fields: [senderId], references: [id])
  reads          MessageRead[]

  @@index([conversationId, createdAt])
  @@index([senderId])
}

model MessageRead {
  id        String   @id @default(uuid())
  messageId String
  userId    String
  readAt    DateTime @default(now())
  message   Message  @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id])

  @@unique([messageId, userId])
  @@index([userId])
}

model UserBlock {
  id        String   @id @default(uuid())
  blockerId String
  blockedId String
  createdAt DateTime @default(now())
  blocked   User     @relation("Blocked", fields: [blockedId], references: [id])
  blocker   User     @relation("BlockedBy", fields: [blockerId], references: [id])

  @@unique([blockerId, blockedId])
  @@index([blockerId])
  @@index([blockedId])
}

enum Gender {
  MALE
  FEMALE
}

enum RelationStatus {
  PENDING
  CONFIRMED
  REJECTED
}

enum RelationCategory {
  FAMILY
  FRIEND
}

enum NotificationType {
  RELATION_REQUEST
  RELATION_APPROVED
  RELATION_REJECTED
  POST_LIKE
  POST_COMMENT
  POST_SHARE
  FOLLOW_REQUEST
  FOLLOW_ACCEPTED
}

enum NotificationState {
  UNREAD
  READ
}

enum FollowStatus {
  PENDING
  ACCEPTED
}

enum MemberRole {
  ADMIN
  MEMBER
}

enum MessageType {
  TEXT
  MEDIA
  SYSTEM
}

enum MediaType {
  PHOTO
  VIDEO
  DOCUMENT
}
