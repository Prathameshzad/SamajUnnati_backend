generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma/client"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                                  String         @id @default(uuid())
  phone                               String?        @unique
  email                               String?        @unique
  photoUrl                            String?
  address                             String?
  pincode                             String?
  designation                         String?
  dateOfBirth                         DateTime?
  createdAt                           DateTime       @default(now())
  updatedAt                           DateTime       @updatedAt
  gender                              Gender?
  area                                String?
  bloodGroup                          String?
  community                           String?
  education                           String?
  firstName                           String?
  lastName                            String?
  maritalStatus                       String?
  matrimonialStatus                   String?
  middleName                          String?
  occupation                          String?
  occupationDetails                   String?
  religion                            String?
  whatsapp                            String?
  profileCompleted                    Boolean        @default(false)
  deletedAt                           DateTime?
  notifications                       Notification[]
  Relation_Relation_createdByIdToUser Relation[]     @relation("Relation_createdByIdToUser")
  relationsFrom                       Relation[]     @relation("UserRelationsFrom")
  relationsTo                         Relation[]     @relation("UserRelationsTo")

  @@index([phone])
  @@index([email])
}

model RelationType {
  code           String                @id
  category       RelationCategory
  targetGender   Gender?
  treeLevel      Int?
  reciprocalCode String?
  relations      Relation[]
  translations   RelationTranslation[]

  @@index([category])
}

model RelationTranslation {
  id               String       @id @default(uuid())
  relationTypeCode String
  languageCode     String
  community        String?
  label            String
  createdAt        DateTime     @default(now())
  relationType     RelationType @relation(fields: [relationTypeCode], references: [code])

  @@unique([relationTypeCode, languageCode, community])
  @@index([languageCode])
}

model Relation {
  id                              String           @id @default(uuid())
  fromUserId                      String
  toUserId                        String
  status                          RelationStatus   @default(PENDING)
  createdAt                       DateTime         @default(now())
  updatedAt                       DateTime         @updatedAt
  relationTypeCode                String
  customName                      String?
  customPhotoUrl                  String?
  category                        RelationCategory
  createdById                     String?
  deletedAt                       DateTime?
  notifications                   Notification[]
  User_Relation_createdByIdToUser User?            @relation("Relation_createdByIdToUser", fields: [createdById], references: [id])
  fromUser                        User             @relation("UserRelationsFrom", fields: [fromUserId], references: [id])
  relationType                    RelationType     @relation(fields: [relationTypeCode], references: [code])
  toUser                          User             @relation("UserRelationsTo", fields: [toUserId], references: [id])

  @@unique([fromUserId, toUserId, relationTypeCode])
  @@index([fromUserId])
  @@index([toUserId])
  @@index([relationTypeCode])
  @@index([category])
  @@index([status])
}

model Notification {
  id         String            @id @default(uuid())
  userId     String
  type       NotificationType
  title      String
  message    String
  relationId String?
  state      NotificationState @default(UNREAD)
  createdAt  DateTime          @default(now())
  readAt     DateTime?
  relation   Relation?         @relation(fields: [relationId], references: [id])
  user       User              @relation(fields: [userId], references: [id])

  @@index([userId, state, createdAt])
  @@index([relationId])
}

enum Gender {
  MALE
  FEMALE
}

enum RelationStatus {
  PENDING
  CONFIRMED
  REJECTED
}

enum RelationCategory {
  FAMILY
  FRIEND
}

enum NotificationType {
  RELATION_REQUEST
  RELATION_APPROVED
  RELATION_REJECTED
}

enum NotificationState {
  UNREAD
  READ
}
